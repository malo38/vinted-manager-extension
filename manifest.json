{
  "manifest_version": 3,
  "name": "Vinted Manager",
  "version": "1.1.0",
  "description": "Synchronise automatiquement votre compte Vinted avec Vinted Manager",
  "permissions": ["storage", "alarms", "tabs", "scripting", "notifications"],
  "host_permissions": [
    "https://www.vinted.fr/*",
    "https://web-production-662dc1.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
